# Pauza miedzy tickerami w sekundach (lagodzi ryzyko chwilowej blokady IP).
SCREENER_PAUSE=0.4

# Wzbogacanie overview danymi z Finviz: 1 = wlaczone, 0 = wylaczone.
SCREENER_USE_FINVIZ=1
